---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { getPostsByTag } from "@/utils/getPostsByTag";

const allPosts = await getCollection("posts");
const tags = getUniqueTags(allPosts);
const tagsWithCounts = tags.map((tag) => ({
  tag,
  count: getPostsByTag(allPosts, tag).length,
}));
---

<Layout title="Tags — sa/acc" description="Browse posts by tag">
  <Header />

  <main class="flex-grow z-10 pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="text-3xl font-bold mb-2 text-[#e6edf3]">
        <span class="lang-en">Tags</span>
        <span class="lang-ar">الوسوم</span>
      </h1>
      <p class="text-[#8b949e] mb-10">
        <span class="lang-en">Browse posts by tag</span>
        <span class="lang-ar">تصفح المقالات حسب الوسم</span>
      </p>

      {tagsWithCounts.length === 0 ? (
        <p class="text-[#6E6E6E] text-center py-16">
          <span class="lang-en">No tags yet.</span>
          <span class="lang-ar">لا توجد وسوم بعد.</span>
        </p>
      ) : (
        <div class="flex flex-wrap gap-3">
          {tagsWithCounts.map(({ tag, count }) => (
            <a
              href={`/tags/${tag}`}
              class="inline-flex items-center gap-2 bg-[#171717] border border-[#252525] hover:border-[#3fb950]/50 rounded-lg px-4 py-2 transition-colors"
            >
              <span class="text-xs font-bold uppercase tracking-widest text-[#3fb950]">{tag}</span>
              <span class="text-xs text-[#6E6E6E]">{count}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
