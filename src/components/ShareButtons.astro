---
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<div class="flex items-center gap-3 mt-12 pt-6 border-t border-[#252525]">
  <span class="text-xs uppercase tracking-widest text-[#6E6E6E]">
    <span class="lang-en">Share</span>
    <span class="lang-ar">شارك</span>
  </span>
  <a
    href={twitterUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on X/Twitter"
    class="text-[#8b949e] hover:text-[#3fb950] transition-colors"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
  </a>
  <a
    href={linkedinUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on LinkedIn"
    class="text-[#8b949e] hover:text-[#3fb950] transition-colors"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
  </a>
  <button
    type="button"
    data-share-copy
    data-url={url}
    aria-label="Copy link"
    class="text-[#8b949e] hover:text-[#3fb950] transition-colors"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
  </button>
  <span data-share-status class="text-xs text-[#3fb950] opacity-0 transition-opacity"></span>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-share-copy]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-url") ?? window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        const status = btn.parentElement?.querySelector<HTMLElement>("[data-share-status]");
        if (status) {
          status.textContent = document.documentElement.lang === "ar" ? "تم النسخ" : "Copied";
          status.style.opacity = "1";
          setTimeout(() => {
            status.style.opacity = "0";
          }, 1500);
        }
      } catch (err) {
        console.error("Failed to copy URL", err);
      }
    });
  });
</script>
