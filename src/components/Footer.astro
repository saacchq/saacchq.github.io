---
import { config } from "@/config";
import { getTranslation } from "@/i18n";
---

<footer class="border-t border-[#30363d] bg-[#161b22] relative">
  <div class="max-w-7xl mx-auto py-8 px-6 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] text-[#8b949e] uppercase tracking-[0.2em]">
    <div class="font-bold">
      <span class="lang-ar">{getTranslation("ar", "footer.copy")}</span>
      <span class="lang-en">{getTranslation("en", "footer.copy")}</span>
    </div>
    <div class="flex gap-6">
      <a href={config.social.twitter} target="_blank" rel="noreferrer" class="hover:text-[#e6edf3] transition-colors">
        <span class="lang-ar">{getTranslation("ar", "footer.twitter")}</span>
        <span class="lang-en">{getTranslation("en", "footer.twitter")}</span>
      </a>
      <a href={config.social.discord} target="_blank" rel="noreferrer" class="hover:text-[#e6edf3] transition-colors">
        <span class="lang-ar">{getTranslation("ar", "footer.discord")}</span>
        <span class="lang-en">{getTranslation("en", "footer.discord")}</span>
      </a>
      <a href={config.social.github} target="_blank" rel="noreferrer" class="hover:text-[#e6edf3] transition-colors">
        <span class="lang-ar">{getTranslation("ar", "footer.github")}</span>
        <span class="lang-en">{getTranslation("en", "footer.github")}</span>
      </a>
    </div>
  </div>
</footer>
