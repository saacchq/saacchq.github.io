---
import { config } from "@/config";
import { getTranslation } from "@/i18n";
---

<!-- Hero -->
<header class="px-6 max-w-4xl mx-auto text-center flex flex-col items-center mb-16">
  <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-[#e6edf3] pb-4">
    sa/acc<span class="cursor-blink text-[#3fb950]">_</span>
  </h1>
  <h2 class="text-sm md:text-base font-bold text-[#8b949e] mt-4 uppercase tracking-[0.3em] border border-[#30363d] py-3 inline-block px-6 bg-[#161b22]">
    <span class="lang-ar">{getTranslation("ar", "hero.subtitle")}</span>
    <span class="lang-en">{getTranslation("en", "hero.subtitle")}</span>
  </h2>
  <p class="mt-8 text-sm md:text-base text-[#8b949e] max-w-2xl leading-relaxed i18n-body">
    <span class="lang-ar">{getTranslation("ar", "hero.intro")}</span>
    <span class="lang-en">{getTranslation("en", "hero.intro")}</span>
  </p>
</header>

<!-- Global Meeting Badge -->
<section class="px-6 max-w-4xl mx-auto mb-12 flex justify-center">
  <div class="inline-flex items-center gap-3 text-xs text-[#3fb950] border border-[#3fb950]/30 bg-[#3fb950]/5 px-5 py-2.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
    <span class="uppercase tracking-widest font-bold">
      <span class="lang-ar">{getTranslation("ar", "meeting.label")}</span>
      <span class="lang-en">{getTranslation("en", "meeting.label")}</span>
    </span>
    <span class="text-[#8b949e]">
      <span class="lang-ar">— {config.meeting.scheduleAr}</span>
      <span class="lang-en">— {config.meeting.schedule}</span>
    </span>
  </div>
</section>

<!-- Manifesto Table -->
<section class="px-6 max-w-4xl mx-auto mb-24">
  <div class="flex flex-col border border-[#30363d] bg-[#161b22]/50">
    {config.manifesto.map((item, idx) => (
      <div class:list={["flex flex-col md:flex-row", idx < config.manifesto.length - 1 && "border-b border-[#30363d]"]}>
        {/* Number column */}
        <div class="md:w-20 flex-shrink-0 border-b md:border-b-0 md:border-e border-[#30363d] p-4 flex items-start justify-center">
          <span class="text-[#3fb950] font-bold text-xs">{item.id}</span>
        </div>
        {/* Content */}
        <div class="p-6 flex-grow">
          <h3 class="text-sm font-bold text-[#e6edf3] uppercase tracking-widest mb-2">
            <span class="lang-ar">{getTranslation("ar", `manifesto.${idx + 1}.title`)}</span>
            <span class="lang-en">{getTranslation("en", `manifesto.${idx + 1}.title`)}</span>
          </h3>
          <p class="text-[#8b949e] leading-relaxed text-sm i18n-body">
            <span class="lang-ar">{getTranslation("ar", `manifesto.${idx + 1}.body`)}</span>
            <span class="lang-en">{getTranslation("en", `manifesto.${idx + 1}.body`)}</span>
          </p>
          <div class="mt-4 inline-flex items-center gap-2 text-[10px] text-[#3fb950] border border-[#3fb950]/30 bg-[#3fb950]/5 px-3 py-1.5">
            <span class="uppercase tracking-widest font-bold">{item.tag}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Partners & Associations -->
<section class="px-6 max-w-4xl mx-auto mb-24 grid md:grid-cols-2 gap-8">
  {/* Partners */}
  <div class="border border-[#30363d] p-8 bg-[#161b22]/30">
    <h4 class="text-xs font-bold text-[#8b949e] uppercase tracking-widest mb-6 flex items-center gap-2">
      <span class="w-2 h-2 bg-[#3fb950] rounded-full"></span>
      <span class="lang-ar">{getTranslation("ar", "partners.title")}</span>
      <span class="lang-en">{getTranslation("en", "partners.title")}</span>
    </h4>
    {config.partners.map((partner) => (
      <a href={partner.url} target="_blank" rel="noreferrer" class="group flex items-center gap-4 p-4 border border-[#30363d] hover:border-[#3fb950] transition-colors">
        <img src={partner.logo} alt={partner.name} width="40" height="40" class="flex-shrink-0 rounded" />
        <div class="flex-grow">
          <div class="text-base font-bold text-[#e6edf3] group-hover:text-[#3fb950] transition-colors">{partner.name}</div>
          <div class="text-[11px] text-[#8b949e] group-hover:text-[#3fb950] transition-colors">{partner.urlLabel} &rarr;</div>
        </div>
      </a>
    ))}
  </div>

  {/* Associations */}
  <div class="border border-[#30363d] p-8 bg-[#161b22]/30">
    <h4 class="text-xs font-bold text-[#8b949e] uppercase tracking-widest mb-6 flex items-center gap-2">
      <span class="w-2 h-2 bg-blue-400 rounded-full"></span>
      <span class="lang-ar">{getTranslation("ar", "associations.title")}</span>
      <span class="lang-en">{getTranslation("en", "associations.title")}</span>
    </h4>
    {config.associations.map((assoc) => (
      <a href={assoc.url} target="_blank" rel="noreferrer" class="group flex items-center gap-4 p-4 border border-[#30363d] hover:border-[#e6edf3] transition-colors">
        <img src={assoc.logo} alt={assoc.name} width="40" height="40" class="flex-shrink-0 rounded" />
        <div class="flex-grow">
          <div class="text-base font-bold text-[#e6edf3] group-hover:text-[#e6edf3] transition-colors">{assoc.name}</div>
          <div class="text-[11px] text-[#8b949e] group-hover:text-[#e6edf3] transition-colors">{assoc.urlLabel} &rarr;</div>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- CTA -->
<section id="join" class="px-6 text-center flex flex-col items-center gap-6 mb-12">
  <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
    <a
      href={config.social.discord}
      target="_blank"
      rel="noreferrer"
      class="px-8 py-4 bg-[#3fb950] text-[#0d1117] text-xs font-bold uppercase tracking-widest hover:brightness-110 transition-all flex items-center justify-center gap-3 w-full sm:w-auto"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 71 55" fill="currentColor"><path d="M60.1 4.9A58.5 58.5 0 0 0 45.7.2a.2.2 0 0 0-.2.1 40.8 40.8 0 0 0-1.8 3.7 54 54 0 0 0-16.2 0A37.4 37.4 0 0 0 25.6.3a.2.2 0 0 0-.2-.1A58.4 58.4 0 0 0 11 4.9a.2.2 0 0 0-.1.1C1.6 18.4-.9 31.5.3 44.5a.3.3 0 0 0 .1.2 58.7 58.7 0 0 0 17.7 9 .2.2 0 0 0 .3-.1 42 42 0 0 0 3.6-5.9.2.2 0 0 0-.1-.3 38.7 38.7 0 0 1-5.5-2.6.2.2 0 0 1 0-.4l1.1-.9a.2.2 0 0 1 .2 0 41.9 41.9 0 0 0 35.6 0 .2.2 0 0 1 .2 0l1.1.9a.2.2 0 0 1 0 .4 36.3 36.3 0 0 1-5.5 2.6.2.2 0 0 0-.1.3 47.2 47.2 0 0 0 3.6 5.9.2.2 0 0 0 .3.1 58.5 58.5 0 0 0 17.7-9 .2.2 0 0 0 .1-.2c1.4-15-2.3-28-9.8-39.5a.2.2 0 0 0-.1-.1ZM23.7 36.5c-3.4 0-6.3-3.2-6.3-7s2.8-7 6.3-7c3.5 0 6.4 3.1 6.3 7 0 3.9-2.8 7-6.3 7Zm23.3 0c-3.4 0-6.3-3.2-6.3-7s2.8-7 6.3-7c3.5 0 6.4 3.1 6.3 7 0 3.9-2.8 7-6.3 7Z"/></svg>
      <span class="lang-ar">{getTranslation("ar", "cta.discord")}</span>
      <span class="lang-en">{getTranslation("en", "cta.discord")}</span>
    </a>
    <a
      href={config.social.twitter}
      target="_blank"
      rel="noreferrer"
      class="px-8 py-4 bg-transparent border border-[#30363d] text-[#e6edf3] text-xs font-bold uppercase tracking-widest hover:border-[#8b949e] transition-colors flex items-center justify-center gap-3 w-full sm:w-auto"
    >
      <span class="lang-ar">{getTranslation("ar", "cta.follow")}</span>
      <span class="lang-en">{getTranslation("en", "cta.follow")}</span>
    </a>
  </div>
</section>
